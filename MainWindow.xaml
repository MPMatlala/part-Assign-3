<Window x:Class="CyberBot3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="680" Width="900"
        MinHeight="580" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#3E2723">

    <Window.Resources>
        <!-- Brown colour palette -->
        <SolidColorBrush x:Key="DarkBrown"    Color="#3E2723"/>
        <SolidColorBrush x:Key="MedBrown"     Color="#5D4037"/>
        <SolidColorBrush x:Key="LightBrown"   Color="#8D6E63"/>
        <SolidColorBrush x:Key="Cream"        Color="#EFEBE9"/>
        <SolidColorBrush x:Key="Accent"       Color="#FF8F00"/>
        <SolidColorBrush x:Key="AccentDark"   Color="#E65100"/>
        <SolidColorBrush x:Key="White"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BotBubble"    Color="#4E342E"/>
        <SolidColorBrush x:Key="UserBubble"   Color="#6D4C41"/>

        <!-- Rounded button style -->
        <Style x:Key="BrownButton" TargetType="Button">
            <Setter Property="Background"   Value="#FF8F00"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E65100"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#8D6E63"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small danger button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BrownButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Success button -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BrownButton}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="BrownTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#4E342E"/>
            <Setter Property="Foreground"       Value="#EFEBE9"/>
            <Setter Property="CaretBrush"       Value="#FF8F00"/>
            <Setter Property="BorderBrush"      Value="#FF8F00"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <!-- Tab item style -->
        <Style x:Key="BrownTab" TargetType="TabItem">
            <Setter Property="Background"  Value="#5D4037"/>
            <Setter Property="Foreground"  Value="#EFEBE9"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6,6,0,0"
                                Margin="2,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF8F00"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#8D6E63"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ══════════════════════════════════════════════
             HOME PAGE
             ══════════════════════════════════════════════ -->
        <Grid x:Name="HomeGrid" Visibility="Visible">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3E2723" Offset="0"/>
                    <GradientStop Color="#5D4037" Offset="0.5"/>
                    <GradientStop Color="#4E342E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="550">

                <!-- Shield icon ASCII -->
                <TextBlock FontFamily="Courier New" FontSize="13"
                           Foreground="#FF8F00" TextAlignment="Center"
                           Margin="0,0,0,10" LineHeight="18">
                    <Run Text="   ██████╗██╗   ██╗██████╗ ███████╗██████╗ ██████╗  ██████╗ ████████╗"/>
                    <LineBreak/>
                    <Run Text="  ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚══██╔══╝"/>
                    <LineBreak/>
                    <Run Text="  ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝██████╔╝██║   ██║   ██║   "/>
                    <LineBreak/>
                    <Run Text="  ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗██╔══██╗██║   ██║   ██║   "/>
                    <LineBreak/>
                    <Run Text="  ╚██████╗   ██║   ██████╔╝███████╗██║  ██║██████╔╝╚██████╔╝   ██║   "/>
                    <LineBreak/>
                    <Run Text="   ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═════╝  ╚═════╝   ╚═╝   "/>
                </TextBlock>

                <!-- Logo image from Part 2 -->
                <Image Source="myLogo.jpg"
                       Width="300" Height="170"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,10"
                       Stretch="Uniform"/>

                <TextBlock Text="🛡 CyberBot 3.0" FontSize="32" FontWeight="Bold"
                           Foreground="White" TextAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Text="Advanced Cybersecurity Awareness Assistant"
                           FontSize="15" Foreground="#EFEBE9"
                           TextAlignment="Center" Margin="0,0,0,4"/>

                <TextBlock Text="Tasks • Quiz • NLP • Activity Log"
                           FontSize="12" Foreground="#FF8F00"
                           TextAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="HomeStartBtn" Content="🚀  Get Started"
                        Style="{StaticResource BrownButton}"
                        Width="200" Height="50" FontSize="17"
                        HorizontalAlignment="Center"
                        Click="HomeStartBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════
             USERNAME PAGE
             ══════════════════════════════════════════════ -->
        <Grid x:Name="UsernameGrid" Visibility="Hidden">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3E2723" Offset="0"/>
                    <GradientStop Color="#5D4037" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="👤 Who Am I Talking To?" FontSize="26" FontWeight="Bold"
                           Foreground="White" TextAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Enter your name to start chatting."
                           FontSize="13" Foreground="#EFEBE9"
                           TextAlignment="Center" Margin="0,0,0,24"/>

                <TextBox x:Name="UsernameInput" Height="45"
                         Style="{StaticResource BrownTextBox}"
                         Margin="0,0,0,6"
                         KeyDown="UsernameInput_KeyDown"/>

                <TextBlock x:Name="UsernameErrorText" Text="" FontSize="12"
                           Foreground="#FF5722" TextAlignment="Center" Margin="0,0,0,12"/>

                <Button Content="Continue ➤" Style="{StaticResource BrownButton}"
                        Height="44" FontSize="15"
                        Click="SubmitNameBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════
             MAIN CHAT + FEATURE AREA
             ══════════════════════════════════════════════ -->
        <Grid x:Name="MainGrid" Visibility="Hidden">
            <Grid.Background>
                <SolidColorBrush Color="#3E2723"/>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="#5D4037">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🛡 CyberBot 3.0  —  " FontSize="18"
                                   FontWeight="Bold" Foreground="#FF8F00" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderUsername" Text="" FontSize="18"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🚪 Exit"
                            Style="{StaticResource DangerButton}"
                            Height="32" FontSize="12"
                            Click="ExitBtn_Click"/>
                </Grid>
            </Border>

            <!-- Tab Control -->
            <TabControl Grid.Row="1" Background="#3E2723"
                        BorderBrush="#5D4037" BorderThickness="0,2,0,0">

                <!-- ─────────────────────────────────────
                     TAB 1 : CHAT
                     ───────────────────────────────────── -->
                <TabItem Header="💬 Chat" Style="{StaticResource BrownTab}">
                    <Grid Background="#3E2723">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Chat messages list -->
                        <ListBox x:Name="ChatListBox" Grid.Row="0"
                                 Background="#3E2723" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Margin="10,10,10,0" Padding="4"/>

                        <!-- Input row -->
                        <Border Grid.Row="1" Background="#4E342E"
                                CornerRadius="0" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MessageInput" Grid.Column="0"
                                         Style="{StaticResource BrownTextBox}"
                                         Height="40" Margin="0,0,8,0"
                                         VerticalContentAlignment="Center"
                                         KeyDown="MessageInput_KeyDown"/>
                                <Button Grid.Column="1" Content="Send ➤"
                                        Style="{StaticResource BrownButton}"
                                        Height="40" Width="90"
                                        Click="SendBtn_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ─────────────────────────────────────
                     TAB 2 : TASK ASSISTANT
                     ───────────────────────────────────── -->
                <TabItem Header="📋 Tasks" Style="{StaticResource BrownTab}">
                    <Grid Background="#3E2723" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Add task form -->
                        <Border Grid.Row="0" Background="#4E342E"
                                CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="➕ Add New Cybersecurity Task"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="#FF8F00" Margin="0,0,0,10"/>

                                <TextBlock Text="Task Title:" Foreground="#EFEBE9" Margin="0,0,0,3"/>
                                <TextBox x:Name="TaskTitleInput"
                                         Style="{StaticResource BrownTextBox}"
                                         Height="34" Margin="0,0,0,8"/>

                                <TextBlock Text="Description:" Foreground="#EFEBE9" Margin="0,0,0,3"/>
                                <TextBox x:Name="TaskDescInput"
                                         Style="{StaticResource BrownTextBox}"
                                         Height="34" Margin="0,0,0,8"/>

                                <TextBlock Text="Reminder (e.g. 7 days / 2025-12-01):"
                                           Foreground="#EFEBE9" Margin="0,0,0,3"/>
                                <TextBox x:Name="TaskReminderInput"
                                         Style="{StaticResource BrownTextBox}"
                                         Height="34" Margin="0,0,0,10"/>

                                <Button Content="Add Task" Style="{StaticResource BrownButton}"
                                        Height="36" HorizontalAlignment="Left" Width="120"
                                        Click="AddTaskBtn_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Task list header -->
                        <TextBlock Grid.Row="1" Text="📌 Your Tasks"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#FF8F00" Margin="0,0,0,6"/>

                        <!-- Task list -->
                        <ListBox x:Name="TaskListBox" Grid.Row="2"
                                 Background="#4E342E" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabItem>

                <!-- ─────────────────────────────────────
                     TAB 3 : QUIZ
                     ───────────────────────────────────── -->
                <TabItem Header="🎮 Quiz" Style="{StaticResource BrownTab}">
                    <Grid Background="#3E2723" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Quiz header info -->
                        <Border Grid.Row="0" Background="#4E342E"
                                CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="QuizQuestionNum"
                                               Text="🎮 Cybersecurity Quiz"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#FF8F00"/>
                                    <TextBlock x:Name="QuizScoreText"
                                               Text="Score: 0 / 0"
                                               FontSize="13" Foreground="#EFEBE9"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="▶ Start Quiz"
                                        x:Name="StartQuizBtn"
                                        Style="{StaticResource BrownButton}"
                                        Height="36" Width="110"
                                        Click="StartQuizBtn_Click"/>
                            </Grid>
                        </Border>

                        <!-- Question text -->
                        <Border Grid.Row="1" x:Name="QuizQuestionBorder"
                                Background="#5D4037" CornerRadius="8"
                                Padding="14" Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <TextBlock x:Name="QuizQuestionText"
                                       TextWrapping="Wrap"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>

                        <!-- Answer options -->
                        <StackPanel Grid.Row="2" x:Name="QuizOptionsPanel"
                                    Margin="0,0,0,10" Visibility="Collapsed">
                            <Button x:Name="QuizOpt1" Style="{StaticResource BrownButton}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Margin="0,0,0,6" Click="QuizOpt_Click"/>
                            <Button x:Name="QuizOpt2" Style="{StaticResource BrownButton}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Margin="0,0,0,6" Click="QuizOpt_Click"/>
                            <Button x:Name="QuizOpt3" Style="{StaticResource BrownButton}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Margin="0,0,0,6" Click="QuizOpt_Click"/>
                            <Button x:Name="QuizOpt4" Style="{StaticResource BrownButton}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Click="QuizOpt_Click"/>
                        </StackPanel>

                        <!-- True/False options -->
                        <StackPanel Grid.Row="3" x:Name="QuizTFPanel"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10" Visibility="Collapsed">
                            <Button x:Name="QuizTrueBtn" Content="✔ True"
                                    Style="{StaticResource SuccessButton}"
                                    Height="40" Width="120" Margin="0,0,10,0"
                                    Click="QuizTF_Click"/>
                            <Button x:Name="QuizFalseBtn" Content="✖ False"
                                    Style="{StaticResource DangerButton}"
                                    Height="40" Width="120"
                                    Click="QuizTF_Click"/>
                        </StackPanel>

                        <!-- Feedback -->
                        <Border Grid.Row="4" x:Name="QuizFeedbackBorder"
                                CornerRadius="8" Padding="12"
                                Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock x:Name="QuizFeedbackText"
                                       TextWrapping="Wrap"
                                       FontSize="13" Foreground="White"/>
                        </Border>

                        <!-- Next question button -->
                        <Button Grid.Row="5" x:Name="QuizNextBtn"
                                Content="Next Question ➤"
                                Style="{StaticResource BrownButton}"
                                Height="38" HorizontalAlignment="Left"
                                Width="160" Visibility="Collapsed"
                                Click="QuizNextBtn_Click"/>
                    </Grid>
                </TabItem>

                <!-- ─────────────────────────────────────
                     TAB 4 : ACTIVITY LOG
                     ───────────────────────────────────── -->
                <TabItem Header="📜 Activity Log" Style="{StaticResource BrownTab}">
                    <Grid Background="#3E2723" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📜 Recent Activity (last 10 actions)"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#FF8F00"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="🗑 Clear Log"
                                    Style="{StaticResource DangerButton}"
                                    Height="32" Width="100"
                                    Click="ClearLogBtn_Click"/>
                        </Grid>

                        <ListBox x:Name="ActivityLogListBox" Grid.Row="1"
                                 Background="#4E342E" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>
